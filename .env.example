# Anthropic (Claude) — get from https://platform.claude.com
ANTHROPIC_API_KEY=sk-ant-...

# Loyverse — Back Office > Integrations > Access tokens
LOYVERSE_ACCESS_TOKEN=your-loyverse-token
# The one branch this bot answers for (must match the store name in Loyverse).
# Leave empty to cover all stores.
LOYVERSE_STORE_NAME=FOUR WHEELS ZONE

# Meta Messenger — from developers.facebook.com app dashboard
PAGE_ACCESS_TOKEN=your-page-access-token
# Any random string you invent; must match what you type in the Meta webhook setup form
VERIFY_TOKEN=my-secret-verify-token
# App Dashboard > App settings > Basic > App secret — used to verify that
# webhook calls really come from Meta (recommended in production)
APP_SECRET=your-app-secret

PORT=3000
